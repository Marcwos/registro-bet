SECRET_KEY=your-secret-key-here
DEBUG=True

# ─── Base de datos (desarrollo - Docker) ────────────────
POSTGRES_DB=registro_bet
POSTGRES_USER=bet_user
POSTGRES_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5433

# ─── Base de datos (produccion - Supabase) ──────────────
# Si DATABASE_URL esta definida, se ignoran las variables individuales
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── CORS ───────────────────────────────────────────────
# Separar multiples origenes con coma
# CORS_ALLOWED_ORIGINS=https://tu-app.vercel.app,http://localhost:5173

# ─── Hosts permitidos ──────────────────────────────────
# ALLOWED_HOSTS=tu-app.onrender.com,localhost

# ─── Email (produccion: configurar SMTP) ───────────────
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
